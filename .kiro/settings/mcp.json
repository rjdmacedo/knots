{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {},
      "disabled": true,
      "autoApprove": []
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "autoApprove": [
        "search_items_in_registries",
        "view_items_in_registries",
        "get_item_examples_from_registries"
      ]
    }
  }
}
